# User Codespace owner as actor
--actor $GITHUB_USER

# Load variables and secrets from files
--secret-file /workspaces/exercise-creator/.actrc.secrets
--var-file /workspaces/exercise-creator/.actrc.vars
--env-file /workspaces/exercise-creator/.actrc.env

# Cache used Actions
--action-offline-mode

# Use Skills runner image
-P ubuntu-latest=ubuntu-skills:latest

# Run as AMD64 if on ARM64
--container-architecture linux/amd64
