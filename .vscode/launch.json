{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Action (related to current file)",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "envFile": "${fileDirname}/.env.debug",
            "env": {
                "GITHUB_ACTIONS": "true", // Worklflow won't run unless it thinks the environment is a GitHub Action
            },
            "program": "${fileDirname}/index.js",
            "cwd": "${fileDirname}"
        }
    ]
}