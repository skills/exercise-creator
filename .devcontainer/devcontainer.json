{
  "image": "mcr.microsoft.com/devcontainers/base:jammy",

  // Ref: https://containers.dev/features
  "features": {
    // Developing Actions workflows
    // "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}, // Use this if running locally as a Dev Container
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}, // Use this if running as a Codespace
    "ghcr.io/dhoeric/features/act:1": {},
    "ghcr.io/devcontainers-extra/features/actionlint:1": {},
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts",
      "pnpmVersion": "latest",
      "nvmVersion": "latest"
    },

    // Consistent formatting
    "ghcr.io/devcontainers-extra/features/prettier:1": {},

    // Python Support
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.13"
    },

    // General
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  "customizations": {
    "codespaces": {
      "openFiles": ["README.md"]
    },

    "vscode": {
      "extensions": [
        // Styling docs for GitHub website
        "bierner.github-markdown-preview",
        "yahyabatulu.vscode-markdown-alert",
        "davidanson.vscode-markdownlint",
        "rvest.vs-code-prettier-eslint",
        "yzhang.markdown-all-in-one",
        "streetsidesoftware.code-spell-checker",

        // Developing Actions workflows
        "github.vscode-github-actions",
        "me-dutour-mathieu.vscode-github-actions",
        "redhat.vscode-yaml",

        // Managing docker images and containers
        "ms-azuretools.vscode-docker",

        // General Coding
        "github.copilot",
        "esbenp.prettier-vscode",
        "github.vscode-pull-request-github",
        "hediet.vscode-drawio",
        "ryanluker.vscode-coverage-gutters",

        // Python support
        "ms-python.python",
        "ms-python.vscode-pylance",

        // Javascript support
        "dbaeumer.vscode-eslint",
        "Orta.vscode-jest"
      ],

      "settings": {
        // During Codespace creation, the below settings are copied to
        // the machine settings in the following location.
        // /home/vscode/.vscode-remote/data/Machine/settings.json

        // Git
        "git.autofetch": true,
        "git.allowForcePush": false,
        "git.defaultCloneDirectory": "/workspaces/repos/",

        // By default, VS Code only scans one level deep for git repositories.
        // Setting this to -1 scans to an unlimited depth, which is useful for
        // the nested repository structure in the /workspaces/repos directory.
        "git.repositoryScanMaxDepth": -1,

        // Chat
        "chat.agent.enabled": true,
        "chat.mcp.enabled": true,
        "chat.instructionsFilesLocations": {
          ".github/instructions": true
        },

        // GitHub
        "github.copilot.enabled": true,
        "github.copilot.chat.commitMessageGeneration.instructions": [
          { "file": ".github/instructions/commit-message-style.instructions.md" }
        ],

        // Consistent formatting
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.tabSize": 2,
        "markdown.extension.list.indentationSize": "adaptive",
        "markdown.extension.italic.indicator": "_",
        "markdown.extension.orderedList.marker": "one",

        // Javascript
        "jest.enable": false
      }
    }
  },

  // https://containers.dev/implementors/json_reference/#lifecycle-scripts
  // Tasks to include in the prebuild
  "onCreateCommand": "bash ./.devcontainer/onCreate.sh",

  // Tasks to include when the user starts the container for the first time
  "postCreateCommand": "bash ./.devcontainer/postCreate.sh"
}
